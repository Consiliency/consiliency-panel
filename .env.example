# Supabase (service role — server only, never expose to client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# GitHub tokens (minimum scope per tier)
# guest:      issues:read, metadata:read
# contractor: issues:read, contents:read, metadata:read
# team:       issues:read, contents:read, pull_requests:read, metadata:read
GITHUB_TOKEN_GUEST=github_pat_...
GITHUB_TOKEN_CONTRACTOR=github_pat_...
GITHUB_TOKEN_TEAM=github_pat_...

# Anthropic API key for BAML pipeline
ANTHROPIC_API_KEY=sk-ant-...

# Internal secret for after() → process route communication
PANEL_INTERNAL_SECRET=generate-a-strong-random-secret

# Upstash Redis for rate limiting
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Public vars (safe for client)
NEXT_PUBLIC_PANEL_API_URL=https://panel-api.consiliency.io
