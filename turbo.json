{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "generate": {
      "inputs": ["baml_src/**"],
      "outputs": ["baml_client/**"]
    },
    "build": {
      "dependsOn": ["^build", "generate"],
      "inputs": ["src/**", "tsconfig.json", "package.json"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": [
        "SUPABASE_URL",
        "SUPABASE_SERVICE_KEY",
        "PANEL_INTERNAL_SECRET",
        "ANTHROPIC_API_KEY",
        "GITHUB_TOKEN_GUEST",
        "GITHUB_TOKEN_CONTRACTOR",
        "GITHUB_TOKEN_TEAM",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN"
      ]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "__tests__/**", "*.test.ts", "*.spec.ts"]
    },
    "lint": {
      "inputs": ["src/**", "*.ts", "*.tsx"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
