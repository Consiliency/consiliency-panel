{
  "name": "@consiliency/panel-react",
  "version": "0.2.2",
  "description": "React adapter for @consiliency/panel",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": "./dist/styles/panel.css"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "browser-image-compression": "^2.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Consiliency/consiliency-panel.git"
  }
}