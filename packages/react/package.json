{
  "name": "@consiliency/panel-react",
  "version": "0.2.2",
  "private": false,
  "description": "React adapter for @consiliency/panel",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles": "./src/styles/panel.css"
  },
  "files": ["src"],
